# Dependencies
node_modules/

# Build output
dist/
src-tauri/target/
src-tauri/target-check/

# Environment
.env
.env.local

# Docs internes (non nécessaires dans le repo public).
#
# Rule: every .md is ignored by default, EXCEPT the ones GitHub
# surfaces on the project page (README, LICENSE.md, CHANGELOG,
# SECURITY, PRIVACY, etc.). That way new docs you draft locally
# (roadmaps, briefs, scratchpads…) stay out of the public repo
# unless you explicitly un-ignore them here.
*.md
!/README.md
!/CHANGELOG.md
!/SECURITY.md
!/PRIVACY.md
!/CONTRIBUTING.md
!/CODE_OF_CONDUCT.md
!/LICENSE.md

# Misc internal scratch
rename_script.ps1

# Brainstorm / outils
.superpowers/

# Git worktrees
.worktrees/
.lorica-worktrees/
.claude/

# Project Brain + project-local settings (per-project Lorica state)
.lorica/

# Tauri build artefacts / scratch files
src-tauri/gen/
src-tauri/index.html

